# ============================================================
# Round Table — 환경변수 설정 예시
# 이 파일을 .env로 복사 후 값을 채워넣으세요:
#   cp .env.example .env
# ============================================================

# [필수] Claude Code OAuth 토큰
# 확인 방법: claude auth status
CLAUDE_CODE_OAUTH_TOKEN=your_token_here

# [선택] Claude CLI 경로 (자동 탐지되므로 보통 불필요)
# CLAUDE_BIN=/usr/local/bin/claude

# [선택] 프로젝트 워크스페이스 루트 경로
# 지정하지 않으면 round-table/ 의 상위 디렉토리를 사용
# PROJECT_DIR=/path/to/your/workspace

# [선택] 웹 UI 포트 (기본: 3847)
# PORT=3847

# [선택] 텔레그램 봇 토큰 (PiFl Bot 또는 Claude Bot)
# 텔레그램에서 /debate, /review 명령으로 토론/리뷰 시작
# 완료 시 텔레그램으로 결과 전달
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================
# 멀티 AI 프로바이더 (선택 — 코드 리뷰 토큰 절감용)
# ============================================================

# [선택] OpenAI API 키 — GPT-4o / GPT-4o-mini 사용
# ⚠️  ChatGPT Plus 구독과 별개! platform.openai.com 에서 발급
# 비용: GPT-4o-mini $0.15/1M tokens, GPT-4o $2.50/1M tokens
# OPENAI_API_KEY=sk-proj-...

# [선택] Google Gemini API 키 — Gemini 2.0 Flash 사용
# ✅ 완전 무료! aistudio.google.com 에서 Google 계정으로 발급
# ⚠️  Google Business Starter의 Gemini와 별개 (Workspace 내 어시스턴트 ≠ API)
# 무료 한도: Gemini 2.0 Flash 15 RPM / 1M TPM / 1500 req/day
# GEMINI_API_KEY=AIzaSy...

# ============================================================
# CLI 도구 (OAuth 인증 — API 키 불필요)
# ============================================================

# Codex CLI — ChatGPT 계정 OAuth 인증 (~/.codex/auth.json)
# `codex` 를 터미널에서 실행해 로그인하면 자동 저장됨
# 경로 자동 탐지됨 (보통 설정 불필요)
# CODEX_BIN=/opt/homebrew/bin/codex

# Gemini CLI — Google 계정 OAuth 인증 (~/.gemini/oauth_creds.json)
# `gemini` 를 터미널에서 실행해 로그인하면 자동 저장됨
# 경로 자동 탐지됨 (보통 설정 불필요)
# GEMINI_BIN=/opt/homebrew/bin/gemini

# [선택] 기본 AI 구성 프로파일
# claude:         전부 Claude (기본값)
# mixed:          Claude(탐색) + Gemini REST API(분석)     — GEMINI_API_KEY 필요
# gemini-primary: Claude(탐색 1명) + Gemini REST API       — GEMINI_API_KEY 필요
# gemini-cli:     Claude(탐색) + Gemini CLI(분석)          — gemini 로그인 필요, 무료
# codex-cli:      Claude(탐색) + Codex CLI(분석)           — codex 로그인 필요, 무료
# AI_PROFILE=claude
